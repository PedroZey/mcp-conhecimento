{
  "name": "mcp-conhecimento",
  "version": "0.1.0",
  "description": "Servidor MCP de bases de conhecimento de engenharia (Akita e outros packs).",
  "type": "module",
  "bin": {
    "mcp-conhecimento": "dist/index.js"
  },
  "files": [
    "dist",
    "packs"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "akita",
    "knowledge-base",
    "engenharia"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroZey/mcp-conhecimento.git"
  },
  "homepage": "https://github.com/PedroZey/mcp-conhecimento#readme",
  "bugs": {
    "url": "https://github.com/PedroZey/mcp-conhecimento/issues"
  },
  "author": "PedroZey",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.22.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.43",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
